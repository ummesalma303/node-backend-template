{
    "name": "node-backend-template",
    "version": "1.0.0",
    "packageManager": "pnpm@10.32.1",
    "description": "A starter toolkit for building backend applications with TypeScript and Express.",
    "main": "server.js",
    "scripts": {
        "dev": "node --watch --env-file .env.development src/server.js",
        "start": "node --env-file=.env.production src/server.js",
        "dev:staging": "node --watch --env-file .env.staging src/server.js",
        "dev:prod": "node --watch --env-file .env.production ./src/server.js",
        "test:run": "vitest --run",
        "test:ui": "vitest --ui",
        "coverage": "vitest run --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest",
        "update": "ncu -u",
        "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky install; fi"
    },
    "lint-staged": {
        "*.{js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,yml,yaml,md}": [
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vitest/coverage-v8": "^4.1.0",
        "@vitest/eslint-plugin": "^1.6.12",
        "dotenv-cli": "^11.0.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^5.6.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "npm-check-updates": "^19.6.6",
        "prettier": "^3.8.1",
        "vitest": "^4.1.0"
    },
    "imports": {
        "#*.js": {
            "development":"./src/*.js",
            "default":"./src/*.js"}
    },
    "dependencies": {
        "commander": "^14.0.3",
        "cors": "^2.8.6",
        "dayjs": "^1.11.20",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "rotating-file-stream": "^3.2.9",
        "source-map-support": "^0.5.21"
    },
    "volta": {
        "node": "25.8.1",
        "yarn": "4.12.0"
    }
}
