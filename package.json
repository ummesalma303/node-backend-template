  "description": "",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx --watch --env-file .env src/server.ts",
    "start": "node --env-file .env dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
