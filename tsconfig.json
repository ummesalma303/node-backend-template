{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "allowJs": true,
        "strict": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "rootDir": "./",
        "paths": {
            "@/*": ["./src/*"]
        },

        "types": ["node"]
    },
    "include": ["src", "**/*.js"],
    "exclude": ["node_modules", "dist", "src/**/*.js"]
}
